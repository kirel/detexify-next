{
  "name": "@detexify/data",
  "version": "0.0.0",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "inspect:legacy": "node dist/inspectLegacy.js",
    "inspect:symbols": "node dist/inspectLegacySymbols.js",
    "evaluate:legacy": "node dist/evaluateLegacy.js",
    "add-symbol": "node dist/addSymbol.js",
    "find-bad-samples": "node dist/findBadSamples.js",
    "preview-pr": "node dist/previewPrData.js",
    "build:legacy-manifest": "node dist/buildLegacyManifest.js",
    "benchmark:convnet-nearest": "node dist/benchmarkConvnetNearest.js",
    "train:convnet-embedding": "node dist/trainConvnetEmbedding.js",
    "compare:live-api": "node dist/compareLiveApi.js",
    "convert:legacy-source": "node dist/convertLegacySnapshotToSource.js",
    "render:symbols": "node dist/renderSymbols.js",
    "validate:source": "node dist/validateSourceData.js",
    "prepare:web-data:legacy": "node dist/prepareWebData.js",
    "prepare:web-data": "node dist/prepareWebDataFromSource.js",
    "prepare:mac-web": "node dist/prepareMacWeb.js"
  },
  "dependencies": {
    "@detexify/core": "0.0.0",
    "@tensorflow/tfjs": "^4.22.0",
    "@tensorflow/tfjs-backend-wasm": "^4.22.0",
    "@tensorflow/tfjs-node": "^4.22.0",
    "sharp": "^0.34.5"
  }
}
